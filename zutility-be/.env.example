APP_ENV=dev
HTTP_BIND_ADDR=127.0.0.1:3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/zutility
ORDER_TOKEN_HMAC_SECRET=replace_with_64_plus_random_chars
IP_HASH_SECRET=replace_with_64_plus_random_chars
VTPASS_BASE_URL=https://sandbox.vtpass.com/api
VTPASS_API_KEY=replace_with_vtpass_key
VTPASS_SECRET_KEY=replace_with_vtpass_secret
ZCASH_RPC_MODE=unix
ZCASH_RPC_SOCKET_PATH=/var/run/zcashd/zcashd.sock
ZCASH_RPC_URL=http://127.0.0.1:18232
ZCASH_RPC_USER=replace_with_rpc_user
ZCASH_RPC_PASSWORD=replace_with_rpc_password
ZCASH_NETWORK=testnet
REQUIRED_CONFS_TRANSPARENT=3
REQUIRED_CONFS_SHIELDED=10
ORDER_EXPIRY_MINUTES=30
RATE_LOCK_MINUTES=15
SWEEP_THRESHOLD_ZEC=0.5
SIGNING_SERVICE_URL=http://10.0.0.2:8080
SIGNING_SERVICE_HMAC_SECRET=replace_with_shared_hmac_secret
RATE_SOURCE_TIMEOUT_MS=3000
